        "when": "{agsheath:1b}",
        "model": {
          "type": "minecraft:model",
          "model": "item/agsheath"
        }
      },
      {
        "when": "{bgsheath:1b}",
        "model": {
          "type": "minecraft:model",
          "model": "item/bgsheath"
        }
      },
      { 
        "when": "{blsheath:1b}",
        "model": {
          "type": "minecraft:model",
          "model": "item/blsheath"
        }
      },
      { 
        "when": "{egsheath:1b}",
        "model": {
          "type": "minecraft:model",
          "model": "item/egsheath"
        }
      },
      {
        "when": "{fqsheath:1b}",
        "model": {
          "type": "minecraft:model",
          "model": "item/fqsheath"
        }
      },
      {
        "when": "{nbsheath:1b}",
        "model": {
          "type": "minecraft:model",
          "model": "item/nbsheath"
        }
      }
    ],
     "fallback": {
